{
  "name": "otlplus-web",
  "version": "4.0.0-alpha.1",
  "description": "OTL Plus Web v4 (NextJS)",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --cache --write .",
    "format:nowrite": "prettier --cache --check .",
    "prepare": "husky",
    "husky:pre-commit": "pnpm format:nowrite",
    "husky:pre-push": "pnpm lint && pnpm build"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.67.2",
    "axios": "^1.8.2",
    "loglevel": "^1.9.2",
    "next": "15.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "styled-components": "^6.1.15",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.2.1",
    "eslint-config-prettier": "^10.1.1",
    "eslint-import-resolver-typescript": "^3.8.4",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.3",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "typescript": "^5"
  },
  "engines": {
    "node": "^22.14.0",
    "pnpm": "^10.6.2"
  },
  "packageManager": "pnpm@10.6.2"
}
