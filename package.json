{
    "name": "otlplus-web-v4",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "react-router build",
        "dev": "react-router dev --host",
        "start:client": "vite preview --outDir ./build/client",
        "start:server": "react-router-serve ./build/server/index.js",
        "typecheck": "react-router typegen && tsc",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
        "format:fix": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "prepare": "husky"
    },
    "engines": {
        "node": ">=22.0.0",
        "pnpm": ">=10.0.0"
    },
    "packageManager": "pnpm@10.33.0",
    "dependencies": {
        "@channel.io/channel-web-sdk-loader": "^2.0.2",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/modifiers": "^9.0.0",
        "@dnd-kit/sortable": "^10.0.0",
        "@emotion/css": "^11.13.5",
        "@emotion/is-prop-valid": "^1.4.0",
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^9.0.0",
        "@mui/material": "^9.0.0",
        "@react-router/fs-routes": "^7.14.0",
        "@react-router/node": "^7.14.0",
        "@react-router/serve": "^7.14.0",
        "@sentry/react": "^10.48.0",
        "@tanstack/react-query": "^5.97.0",
        "@tanstack/react-query-devtools": "^5.97.0",
        "@tanstack/react-query-persist-client": "^5.97.0",
        "axios": "^1.15.0",
        "axios-mock-adapter": "^2.1.0",
        "canvas": "^3.2.3",
        "fast-glob": "^3.3.3",
        "framer-motion": "^12.38.0",
        "i18next": "^26.0.4",
        "i18next-browser-languagedetector": "^8.2.1",
        "ical-generator": "^10.1.0",
        "idb-keyval": "^6.2.2",
        "isbot": "^5.1.37",
        "loglevel": "^1.9.2",
        "mixpanel-browser": "^2.78.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-i18next": "^17.0.2",
        "react-intersection-observer": "^10.0.3",
        "react-router": "^7.14.0",
        "react-router-dom": "^7.14.0",
        "zod": "^4.3.6",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.59.1",
        "@react-router/dev": "^7.14.0",
        "@sentry/vite-plugin": "^5.2.0",
        "@tanstack/eslint-plugin-query": "^5.97.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/node": "^22",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "dotenv-cli": "^11.0.0",
        "eslint": "^9.7.0",
        "eslint-plugin-react": "^7.37.5",
        "globals": "^17.4.0",
        "happy-dom": "^20.8.9",
        "husky": "^9.1.7",
        "jsdom": "^29.0.2",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.2",
        "typescript": "^5.1.0",
        "typescript-eslint": "^8.58.1",
        "vite": "^8.0.8",
        "vite-plugin-svgr": "^5.2.0",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.4"
    }
}
